# Copy to .env before using this template manually.
# Do not commit real secrets.

TUSKBASE_POSTGRES_IMAGE=pgvector/pgvector:pg16
TUSKBASE_POSTGRES_HOST=127.0.0.1
TUSKBASE_POSTGRES_PORT=8766
TUSKBASE_POSTGRES_USER=tuskbase
TUSKBASE_POSTGRES_PASSWORD=change-me
TUSKBASE_POSTGRES_DB=tuskbase
TUSKBASE_POSTGRES_VOLUME=tuskbase-local-shared-postgres
