# Tuskbase local configuration examples.
# The preferred setup path is `tuskbase setup`, which generates and stores a local secret for you.
# Normal local MCP clients use `tuskbase bridge`; these env vars are manual HTTP/CI overrides.

# Manual Local Basic bearer key for HTTP MCP and REST.
# TUSKBASE_API_KEY=tbk_replace_with_generated_secret

# Manual Local Shared named keys: name:role:key,name:role:key
# Supported roles: reader, agent, admin.
# TUSKBASE_AGENT_KEYS=codex:agent:tbk_codex_secret,claude:reader:tbk_claude_secret

# HTTP daemon address. Defaults to loopback only.
# TUSKBASE_ADDR=127.0.0.1:8765

# SQLite database path. Defaults to the OS local data directory.
# TUSKBASE_DB_PATH=/path/to/tuskbase.db

# Optional embedding provider. Default is text/no external embeddings.
# TUSKBASE_EMBEDDING_PROVIDER=openai
# TUSKBASE_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_API_KEY=sk_replace_me

# Advanced: allow binding outside loopback. Do not enable casually.
# TUSKBASE_ALLOW_NON_LOOPBACK=true

# Advanced: override where `tuskbase setup` stores local config.
# TUSKBASE_CONFIG_PATH=/path/to/tuskbase-config.json
