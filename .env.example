# Tuskbase local configuration examples.
# The preferred setup path is `tuskbase setup`, which generates and stores a local secret for you.
# Normal local MCP clients use `tuskbase bridge`; these env vars are manual HTTP/CI overrides.

# Manual Local Basic bearer key for HTTP MCP and REST.
# TUSKBASE_API_KEY=tbk_replace_with_generated_secret

# Manual Local Shared named keys: name:role:key,name:role:key
# Supported roles: reader, agent, admin.
# TUSKBASE_AGENT_KEYS=codex:agent:tbk_codex_secret,claude:reader:tbk_claude_secret

# HTTP daemon address. Defaults to loopback only.
# TUSKBASE_ADDR=127.0.0.1:8765

# Durable store selection. SQLite is Demo/Local Basic; Postgres is Local Shared.
# TUSKBASE_STORE=postgres

# SQLite database path. Defaults to the OS local data directory.
# TUSKBASE_DB_PATH=/path/to/tuskbase.db

# Local disaster-recovery backups. Defaults under the Tuskbase local data area.
# Automatic backups run after durable decision/conflict/assessment writes.
# TUSKBASE_BACKUP_DIR=/path/to/tuskbase/backups
# TUSKBASE_BACKUP_AUTO=false
# TUSKBASE_BACKUP_AUTO_RETENTION=20

# Postgres connection for Local Shared. pgx is registered by the standard binary.
# Existing Postgres setup can pass this DSN explicitly or through env.
# TUSKBASE_POSTGRES_DRIVER=pgx
# TUSKBASE_POSTGRES_DSN=postgres://tuskbase:secret@localhost:5432/tuskbase?sslmode=disable

# Docker-managed Local Shared Postgres+pgvector setup overrides.
# Used by `tuskbase setup --mode local-shared` when no Postgres DSN is supplied.
# TUSKBASE_DOCKER_POSTGRES_IMAGE=pgvector/pgvector:pg16
# TUSKBASE_DOCKER_POSTGRES_PORT=8766
# TUSKBASE_DOCKER_CONTEXT=desktop-linux

# Optional embedding provider. Default is text/no external embeddings.
# For local semantic Local Shared retrieval:
# TUSKBASE_EMBEDDING_PROVIDER=ollama
# TUSKBASE_EMBEDDING_MODEL=nomic-embed-text
# TUSKBASE_OLLAMA_BASE_URL=http://127.0.0.1:11434
#
# For OpenAI embeddings instead:
# TUSKBASE_EMBEDDING_PROVIDER=openai
# TUSKBASE_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_API_KEY=sk_replace_me

# Advanced: allow binding outside loopback. Do not enable casually.
# TUSKBASE_ALLOW_NON_LOOPBACK=true

# Advanced: override where `tuskbase setup` stores local config.
# TUSKBASE_CONFIG_PATH=/path/to/tuskbase-config.json
